{
  "name": "tvbox-sync-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "server": "tsx watch src/node.ts",
    "web": "vite",
    "build:worker": "vite build && esbuild src/worker.ts --bundle --platform=neutral --outfile=dist/worker.js",
    "build:node": "vite build && esbuild src/node.ts --bundle --platform=node --outfile=dist/server.js"
  },
