    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-version-mark": "^0.2.2",
    "wait-on": "^9.0.5",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
