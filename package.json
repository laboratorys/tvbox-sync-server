{
  "name": "tvbox-sync-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:cf": "npx kill-port 3000 5173 && npx wrangler pages dev --port 3000 --ip 0.0.0.0 --proxy 5173 -- pnpm run web --host 0.0.0.0",
    "dev": "concurrently --raw \"npm run server\" \"wait-on tcp:3000 && pnpm run web\"",
    "server": "tsx watch src/node.ts",
    "web": "vite",
    "build:web": "vite build",
    "build:server": "esbuild src/node.ts --bundle --platform=node --outfile=dist/server.js",
    "build": "npm run build:web && npm run build:server"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@bprogress/vue": "^1.1.5",
    "@hono/node-server": "^1.19.14",
    "@vueuse/core": "^14.2.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.14",
    "lucide-vue-next": "^1.0.0",
    "otplib": "^13.4.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.32",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9"
  }
}
